{
  "name": "@jameslnewell/configs",
  "private": true,
  "version": "2.0.2",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@jameslnewell/prettier-config": "workspace:*",
    "eslint": "^9.33.0",
    "husky": "^7.0.2",
    "prettier": "^3.5.3",
    "typescript": "^5.9.2"
  },
  "prettier": "@jameslnewell/prettier-config",
  "scripts": {
    "typing:check": "pnpm -r run typing:check",
    "linting:check": "pnpm -r run linting:check",
    "linting:fix": "pnpm -r run linting:fix",
    "formatting:check": "pnpm -r run formatting:check",
    "formatting:fix": "pnpm -r run formatting:fix",
    "test": "pnpm -r run test",
    "release": "changeset publish"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.0"
  }
}
